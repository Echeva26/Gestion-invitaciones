# ─────────────────────────────────────────────────────────────
# Configuración de Abedul Piscina — copia este fichero a .env
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL (Neon en producción).
# Usa la CONNECTION STRING CON POOLER de Neon (contiene "-pooler"), recomendada
# para entornos serverless como Vercel.
#   postgresql://usuario:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Para desarrollo local puedes usar una rama de desarrollo gratuita de Neon
# o un Postgres local (p.ej. Docker: postgres://postgres:postgres@localhost:5432/abedul).
DATABASE_URL="postgresql://usuario:password@host/neondb?sslmode=require"

# Secreto para firmar las sesiones (JWT). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# URL pública de la app (para construir los enlaces mágicos en los emails)
APP_URL="http://localhost:3000"

# ── Envío de email (enlaces mágicos) ──
# Si NO defines SMTP_HOST, en desarrollo el enlace se imprime en consola
# en lugar de enviarse por correo (cómodo para probar sin servidor SMTP).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Piscina Abedul <no-reply@abedul.example>"

# Email del administrador que se crea con el seed inicial
ADMIN_EMAIL="admin@abedul.example"
ADMIN_NAME="Administración Abedul"

# ── Sentry (monitorización de errores en producción) ──
# Opcional en local. Sin DSN, Sentry queda inerte (no envía nada). En producción
# (Vercel) se configura para detectar bugs y disparar el agente de auto-fix.
# Ver docs/auto-fix.md.
SENTRY_DSN=""                 # DSN del servidor (privado), de tu proyecto en Sentry
NEXT_PUBLIC_SENTRY_DSN=""     # DSN del navegador (mismo valor; se expone al cliente)
# Solo para subir source maps en el build (opcional pero recomendado):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
